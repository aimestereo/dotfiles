#!/usr/bin/env bash
#
# devpod ‚Äî toolbox‚Üíhost DevPod CLI bridge. When invoked inside the `tools`
# toolbox, hops to host via flatpak-spawn so the real DevPod binary runs
# against host podman. On host, the fallthrough exec uses the same absolute
# path ‚Äî bypasses PATH, so the wrapper at ~/.local/bin/devpod can't recurse
# into itself.

set -euo pipefail

# Breadcrumb: a bare `devpod up` can't set LOOPBACK_IP, so projects whose
# .devcontainer.json publishes ports via ${localEnv:LOOPBACK_IP} fail deep in
# podman with a cryptic "invalid containerPort". Point at `devpod-up` instead.
# Non-fatal + still passes through, so loopback-free projects keep working.
if [[ "${1:-}" == "up" ]]; then
	echo "devpod: tip ‚Äî use 'devpod-up' (sets per-project LOOPBACK_IP) instead of bare 'devpod up'." >&2
fi

if [[ -f /run/.toolboxenv ]]; then
	exec flatpak-spawn --host /usr/local/bin/devpod "$@"
fi

exec /usr/local/bin/devpod "$@"
