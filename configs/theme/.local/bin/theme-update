#!/usr/bin/env bash
#
# theme-update — sync the omarchy upstream install and render every theme
# into ~/.config/theme/<theme>/ using the vendored theme-set-templates.
#
# Theme + template source: $OMARCHY_PATH (default ~/.local/share/omarchy).
# On first run (no clone present) the upstream is shallow-cloned. Subsequent
# runs git-pull the existing clone. A pre-existing non-git install (e.g.
# omarchy's own tarball install) is used read-only.
#
# On first run (no ~/.config/theme/current yet) the active theme is
# defaulted to catppuccin.

set -euo pipefail

OMARCHY_PATH="${OMARCHY_PATH:-$HOME/.local/share/omarchy}"
repo_url="https://github.com/basecamp/omarchy.git"
branch="dev"
target="$HOME/.config/theme"
default_theme="catppuccin"

err() { printf 'theme-update: %s\n' "$*" >&2; exit 1; }

command -v git >/dev/null || err "missing 'git'"

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
templates_script="$script_dir/theme-set-templates"
[[ -x $templates_script ]] || err "vendored theme-set-templates missing: $templates_script"

if [[ -d $OMARCHY_PATH/.git ]]; then
	echo "Pulling $OMARCHY_PATH..."
	if ! git -C "$OMARCHY_PATH" pull --quiet --ff-only; then
		err "non-fast-forward update at $OMARCHY_PATH; resolve manually (git -C \"$OMARCHY_PATH\" fetch && git -C \"$OMARCHY_PATH\" reset --hard origin/$branch) and re-run"
	fi
elif [[ -d $OMARCHY_PATH ]]; then
	echo "Using existing non-git $OMARCHY_PATH (skipping update)"
else
	echo "Cloning $repo_url ($branch) → $OMARCHY_PATH..."
	mkdir -p "$(dirname "$OMARCHY_PATH")"
	git clone --quiet --depth 1 --branch "$branch" "$repo_url" "$OMARCHY_PATH"
fi

themes_src="$OMARCHY_PATH/themes"
templates_src="$OMARCHY_PATH/default/themed"
[[ -d $themes_src ]] || err "$OMARCHY_PATH missing themes/ directory"
[[ -d $templates_src ]] || err "$OMARCHY_PATH missing default/themed/ directory"

mkdir -p "$target"

for theme_dir in "$themes_src"/*/; do
	theme=$(basename "$theme_dir")
	printf '  %s ... ' "$theme"
	if [[ ! -f $theme_dir/colors.toml ]]; then
		echo "skipped (no colors.toml)"
		continue
	fi
	if ! grep -qE '^[[:space:]]*[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*=[[:space:]]*"#[0-9a-fA-F]+"' "$theme_dir/colors.toml"; then
		echo "skipped (no parseable colors)"
		continue
	fi
	out="$target/$theme"
	mkdir -p "$out"
	# Pre-clear prior template renders so updated palettes propagate; theme-specific
	# upstream overrides are restored by the cp -R below, then preserved by the
	# vendored renderer's skip-if-exists guard. Guarded against the case where an
	# upstream theme ships a directory whose name matches a template basename.
	for tpl in "$templates_src"/*.tpl; do
		stale="$out/$(basename "$tpl" .tpl)"
		[[ -f $stale ]] && rm -f "$stale"
	done
	cp -R "$theme_dir"/. "$out"/
	OMARCHY_PATH="$OMARCHY_PATH" "$templates_script" "$out"
	echo "ok"
done

if [[ ! -e $target/current && ! -L $target/current && -d $target/$default_theme ]]; then
	ln -sfn "$default_theme" "$target/current"
	echo
	echo "current theme → $default_theme (first-run default)"
fi

echo
echo "Themes installed under $target/"
echo "Switch the active theme with: theme-set <name>"
