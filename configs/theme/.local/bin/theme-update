#!/usr/bin/env bash
#
# theme-update — refresh in-repo theme sources from basecamp/omarchy@dev,
# then re-render runtime themes under ~/.config/theme/rendered/.
#
# This script writes INTO the dotfiles repo (configs/theme/.config/theme/themes/
# and configs/theme/.config/theme/themed/). Renders under
# ~/.config/theme/rendered/ are runtime state and never tracked.
#
# UPSTREAM-MIRROR POLICY: configs/theme/.config/theme/themes/<name>/ is a
# mirror of basecamp/omarchy@dev's themes/<name>/ (minus backgrounds/).
# Files added under themes/<name>/ that are NOT in upstream WILL be deleted
# on the next theme-update run (rsync --delete). Put custom overrides in
# configs/theme/.config/theme/themed/*.tpl instead — that directory is also
# upstream-mirrored, but editing a vendored .tpl is the supported extension
# point (your edit persists until the next theme-update overwrites it; then
# you re-apply via git).
#
# SECURITY GATE: upstream omarchy is not pinned and templates render straight
# into terminal/window-manager config files honored on the next live reload.
# Always inspect `git diff configs/theme/.config/theme/` before committing —
# the diff review is the only check between a compromised upstream and the
# next SIGUSR1/SIGUSR2 reload.
#
# Omarchy clone path: $OMARCHY_PATH (default ~/.local/share/omarchy). Cloned on
# first run, git-pulled afterwards. Required only when running theme-update.

set -euo pipefail

OMARCHY_PATH="${OMARCHY_PATH:-$HOME/.local/share/omarchy}"
repo_url="https://github.com/basecamp/omarchy.git"
branch="dev"

err() { printf 'theme-update: %s\n' "$*" >&2; exit 1; }

command -v git >/dev/null || err "missing 'git'"
command -v rsync >/dev/null || err "missing 'rsync'"

script_path=$(readlink -f "${BASH_SOURCE[0]}")
script_dir=$(cd "$(dirname "$script_path")" && pwd)
# configs/theme/.local/bin/theme-update -> repo root is 4 levels up
repo_root=$(cd "$script_dir/../../../.." && pwd)
themes_dst="$repo_root/configs/theme/.config/theme/themes"
themed_dst="$repo_root/configs/theme/.config/theme/themed"
render_script="$script_dir/theme-render"

[[ -d $themes_dst ]] || err "expected $themes_dst — wrong repo root?"
[[ -d $themed_dst ]] || err "expected $themed_dst — wrong repo root?"
[[ -x $render_script ]] || err "vendored theme-render missing: $render_script"

if [[ -d $OMARCHY_PATH/.git ]]; then
	echo "Pulling $OMARCHY_PATH..."
	if ! git -C "$OMARCHY_PATH" pull --quiet --ff-only; then
		err "non-fast-forward update at $OMARCHY_PATH; resolve manually (git -C \"$OMARCHY_PATH\" fetch && git -C \"$OMARCHY_PATH\" reset --hard origin/$branch) and re-run"
	fi
elif [[ -d $OMARCHY_PATH ]]; then
	echo "Using existing non-git $OMARCHY_PATH (skipping update)"
else
	echo "Cloning $repo_url ($branch) → $OMARCHY_PATH..."
	mkdir -p "$(dirname "$OMARCHY_PATH")"
	git clone --quiet --depth 1 --branch "$branch" "$repo_url" "$OMARCHY_PATH"
fi

themes_src="$OMARCHY_PATH/themes"
templates_src="$OMARCHY_PATH/default/themed"
[[ -d $themes_src ]] || err "$OMARCHY_PATH missing themes/ directory"
[[ -d $templates_src ]] || err "$OMARCHY_PATH missing default/themed/ directory"

echo
echo "Refreshing theme sources under $themes_dst (excluding backgrounds/)..."
rsync -a --delete --exclude='backgrounds/' "$themes_src/" "$themes_dst/"

echo "Refreshing templates under $themed_dst..."
rsync -a --delete "$templates_src/" "$themed_dst/"

echo
echo "Re-rendering runtime themes..."
"$render_script"

echo
echo "Done. Review changes in the repo:"
echo "  git -C $repo_root status configs/theme/.config/theme/"
echo "  git -C $repo_root diff configs/theme/.config/theme/"
