#!/usr/bin/env bash
#
# theme-set — switch the active theme by retargeting ~/.config/theme/current
# at one of the rendered themes under ~/.config/theme/rendered/.
#
# Theme catalog (sources) lives at ~/.config/theme/themes/ (stow-managed,
# tracked in the dotfiles repo). Renders are produced on demand by
# theme-render; theme-set will render-on-miss for the selected theme.
#
# Usage:
#   theme-set <name>   # non-interactive
#   theme-set          # interactive picker (fzf if available, numbered menu otherwise)

set -euo pipefail

target="$HOME/.config/theme"
themes_src="$target/themes"
rendered_dst="$target/rendered"
current="$target/current"
default_theme="catppuccin"

err() { printf 'theme-set: %s\n' "$*" >&2; exit 1; }

[[ -d $themes_src ]] || err "no theme sources at $themes_src (run 'make symlinks-*' first)"

script_dir=$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)
render_script="$script_dir/theme-render"
[[ -x $render_script ]] || err "vendored theme-render missing: $render_script"

list_themes() {
	# --format '{/}' returns bare basenames; fd's default appends a trailing
	# slash to directory matches, which would break $out.new staging in
	# theme-render and skew sort order vs. the prior find-based listing.
	fd --base-directory "$themes_src" --type d --min-depth 1 --max-depth 1 --format '{/}' | sort
}

pick_interactive() {
	if command -v fzf >/dev/null; then
		list_themes | fzf --prompt='theme> ' --height=40% || true
		return
	fi
	local themes=() idx choice
	while IFS= read -r line; do
		themes+=("$line")
	done < <(list_themes)
	[[ ${#themes[@]} -eq 0 ]] && err "no themes installed; run 'theme-update' first"
	printf 'Available themes:\n' >&2
	for idx in "${!themes[@]}"; do
		printf '  %2d) %s\n' $((idx + 1)) "${themes[$idx]}" >&2
	done
	read -r -p 'theme> ' choice </dev/tty || true
	if [[ $choice =~ ^[0-9]+$ ]] && ((choice >= 1 && choice <= ${#themes[@]})); then
		printf '%s\n' "${themes[$((choice - 1))]}"
	else
		printf '%s\n' "$choice"
	fi
}

theme=${1:-}
if [[ -z $theme ]]; then
	if [[ ! -e $current && ! -L $current && -d $themes_src/$default_theme ]]; then
		theme=$default_theme
	else
		theme=$(pick_interactive)
	fi
fi
[[ -z $theme ]] && err "no theme selected"

[[ -d $themes_src/$theme ]] || err "theme '$theme' not found under $themes_src/"

# Render on demand if missing or stale-by-absence.
if [[ ! -d $rendered_dst/$theme ]]; then
	"$render_script" "$theme" >/dev/null
fi

ln -sfn "rendered/$theme" "$current"
echo "current theme → $theme"

# Reload running terminals (vendored from omarchy-restart-terminal). Gates use
# captured `ps -A` + bash pattern matching to avoid two macOS pitfalls:
# `pgrep -x ghostty` misses the .app-bundled binary in some shell contexts, and
# `ps -A | grep -q` races with SIGPIPE under `set -o pipefail`.
procs=$(ps -A)
if [[ $procs == *kitty* ]]; then
	killall -SIGUSR1 kitty >/dev/null
fi
if [[ $procs == *ghostty* ]]; then
	killall -SIGUSR2 ghostty >/dev/null
fi
# waybar reloads its stylesheet on SIGUSR2 (SIGUSR1 = visibility toggle).
if [[ $procs == *waybar* ]]; then
	killall -SIGUSR2 waybar >/dev/null
fi
# btop reloads its config + theme on SIGUSR2.
if [[ $procs == *btop* ]]; then
	killall -SIGUSR2 btop >/dev/null
fi
# tmux re-sources its config; its status bar uses native ANSI names that ride
# the terminal palette, so re-sourcing repaints it to the new theme.
if [[ $procs == *tmux* ]]; then
	tmux source-file ~/.config/tmux/tmux.conf >/dev/null 2>&1
fi
# swayosd reads its CSS only at startup (no reload signal), so restart the unit.
# Gated on is-active = clean no-op when absent. `systemctl --user` may not reach
# the per-user bus from a toolbox shell, so this reload is host-context.
if systemctl --user is-active swayosd-server >/dev/null 2>&1; then
	systemctl --user restart swayosd-server >/dev/null
fi
# mako re-reads config (+ its include of the rendered mako.ini) on reload;
# cross-toolbox via the shared PID namespace.
if [[ $procs == *mako* ]]; then
	makoctl reload >/dev/null
fi
