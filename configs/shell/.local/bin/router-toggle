#!/usr/bin/env zsh

ROUTER_A="192.168.1.1"
ROUTER_B="192.168.1.3"
MASK="255.255.255.0"

WIFI_SERVICE="Wi-Fi"
WIFI_IP="192.168.1.21"

ETH_SERVICE="AX88179A"
ETH_IP="192.168.1.22"

current=$(route -n get default 2>/dev/null | awk '/gateway:/ {print $2}')

if [[ -z "$current" ]]; then
    echo "Error: Could not determine current gateway"
    exit 1
fi

echo "Current gateway: $current"

if [[ "$current" == "$ROUTER_A" ]]; then
    new="$ROUTER_B"
elif [[ "$current" == "$ROUTER_B" ]]; then
    new="$ROUTER_A"
else
    echo "Current gateway is neither $ROUTER_A nor $ROUTER_B"
    echo "Setting to $ROUTER_A"
    new="$ROUTER_A"
fi

echo "Switching to: $new"

applied=0

is_valid_ip() {
    [[ -n "$1" && "$1" != *"none"* && "$1" != "(null)" && "$1" != "0.0.0.0" ]]
}

apply_gateway() {
    local service=$1 static_ip=$2
    local active_ip
    active_ip=$(networksetup -getinfo "$service" 2>/dev/null | awk -F': ?' '/^IP address/ {print $2}')
    if is_valid_ip "$active_ip"; then
        echo "Applying to $service ($static_ip -> $new)"
        if sudo networksetup -setmanual "$service" "$static_ip" "$MASK" "$new"; then
            applied=1
        else
            echo "Error: Failed to apply gateway to $service"
        fi
    fi
}

apply_gateway "$WIFI_SERVICE" "$WIFI_IP"
apply_gateway "$ETH_SERVICE" "$ETH_IP"

if [[ $applied -eq 0 ]]; then
    echo "Error: No active network interface found"
    exit 1
fi

echo "Done. New gateway: $(route -n get default 2>/dev/null | awk '/gateway:/ {print $2}')"
