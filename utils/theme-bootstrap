#!/usr/bin/env bash
#
# Render all themes and seed the default ~/.config/theme/current symlink.
# Invoked at the end of the symlinks-* Make targets so a fresh stow yields a
# working theme system with no extra commands. The default-seed step runs
# only when ~/.config/theme/current doesn't already exist — re-stows preserve
# the commander's active theme choice.

set -euo pipefail

"$HOME/.local/bin/theme-render"

current="$HOME/.config/theme/current"
if [[ ! -L $current && ! -e $current ]]; then
	"$HOME/.local/bin/theme-set" catppuccin >/dev/null
fi

# Seed the wallpaper symlink so sway/swaylock have a valid target on first
# boot. Re-stows preserve any wallpaper the commander has set via theme-bg-set.
bg_symlink="$HOME/.config/theme/current-background-image"
default_bg="$HOME/backgrounds/car-with-full-moon-background.jpg"
if [[ ! -L $bg_symlink && ! -e $bg_symlink && -f $default_bg ]]; then
	ln -sfn "$default_bg" "$bg_symlink"
fi

# Tell a running sway to re-read its config so freshly-stowed sway changes
# (output bg / config.d/ bindings / swayidle override) apply without a logout.
# No-op on Mac or when sway isn't running. swayidle is started via `exec`
# (not `exec_always`), so its timeout/lock-bg changes are NOT picked up by
# swaymsg reload — those need a manual `pkill -x swayidle` (then a fresh
# login spawns it with the new args) or a logout/reboot.
if command -v swaymsg >/dev/null && swaymsg -t get_version >/dev/null 2>&1; then
	swaymsg reload >/dev/null
fi
