#!/usr/bin/env bash
#
# install-personal-tools — install commander's personal CLI stack inside the
# `tools` toolbox or inside a DevPod dev container.
#
# Usage:
#   install-personal-tools toolbox    # run inside the toolbox (via `toolbox run`)
#   install-personal-tools devpod     # run inside a dev container (postCreateCommand)
#
# Idempotent: re-runs upgrade in place where possible, skip otherwise.
#
# Single source of truth for "tools I want everywhere" — add a tool once here
# and it lands in both the toolbox AND every DevPod container the next time
# its postCreateCommand runs. Project `.devcontainer.json` files stay free of
# personal-preference noise.

set -euo pipefail

MODE="${1:?usage: $0 [toolbox|devpod]}"
case "$MODE" in
	toolbox|devpod) ;;
	*) echo "install-personal-tools: unknown mode '$MODE' (want toolbox or devpod)" >&2; exit 1 ;;
esac

# xonsh pin tracks PyPI's current stable; bump after smoke-testing locally.
XONSH_VERSION="${XONSH_VERSION:-0.23.7}"

# sd pin tracks chmln/sd's current stable; bump after smoke-testing locally.
SD_VERSION="${SD_VERSION:-1.1.0}"

# claude pinned to dodge the interleaved-thinking resume corruption in 2.1.15x
# (thinking blocks recorded between a tool_use and its tool_result; resume then
# fails with "thinking blocks in the latest assistant message cannot be
# modified"). Autoupdate is already off (~/.claude.json autoUpdates:false,
# native install), so this pin sticks. Bump after the bug is confirmed fixed.
CLAUDE_VERSION="${CLAUDE_VERSION:-2.1.140}"

# ---------------------------------------------------------------------------
# devpod-only: bind-mount sanity check
#
# Docker silently creates an empty directory at a bind-mount target when the
# host source is missing, which would break shell startup if .bashrc / .zshrc /
# .zshenv ended up as directories. Catch that early with a clear message.
# ---------------------------------------------------------------------------
if [[ "$MODE" == "devpod" ]]; then
	for rc in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.zshenv"; do
		if [[ -d "$rc" ]]; then
			echo "install-personal-tools: $rc is a directory — host hasn't run 'make symlinks-fedora' yet." >&2
			exit 1
		fi
	done
fi

# ---------------------------------------------------------------------------
# Shared: dnf packages from Fedora repos
#
# Personal preference stack; non-project-specific. Note tmux is intentionally
# NOT here — see the toolbox-only block below. `sd` is intentionally NOT here
# either — not packaged in Fedora repos; installed from upstream binary below.
# pass (password store), rsync (used by theme-update + general sync), and
# bind-utils (dig / nslookup / host for DNS diagnostics) are shared so they
# land in every DevPod container too, not just the toolbox.
#
# --skip-unavailable lets a re-run survive any single package going missing
# (rename, repo metadata stale) without rolling back the whole transaction.
# ---------------------------------------------------------------------------
sudo dnf install -y --skip-unavailable \
	neovim \
	git \
	git-delta \
	fzf \
	ripgrep \
	fd-find \
	bat \
	eza \
	yazi \
	zoxide \
	tree \
	btop \
	jq \
	gh \
	awscli2 \
	direnv \
	xonsh \
	python3-pip \
	pass \
	rsync \
	bind-utils

# ---------------------------------------------------------------------------
# Toolbox-only: outer-layer-only packages
#
# tmux belongs in the outer layer (sessions span multiple devpod ssh attaches
# into per-project containers; no tmux inside containers). flatpak-xdg-utils
# provides flatpak-spawn — runtime dep for the stowed toolbox→host wrappers
# (devpod, xdg-open, swaymsg under configs/toolbox/.local/bin/).
# stow is needed inside the toolbox because commander runs `make symlinks-fedora`
# from there; devpod containers receive stowed configs via bind mount and don't
# invoke stow themselves.
# ---------------------------------------------------------------------------
if [[ "$MODE" == "toolbox" ]]; then
	sudo dnf install -y --skip-unavailable \
		tmux \
		flatpak-xdg-utils \
		stow \
		chafa
fi

# ---------------------------------------------------------------------------
# Shared: curl installers (upstream-recommended way per app/org)
#
# Set PATH up-front so the `command -v` idempotency checks find binaries
# installed by a previous run. `toolbox run -c tools bash …` invokes a
# non-login non-interactive shell, so user profile files don't get sourced
# and we have to construct PATH explicitly.
# ---------------------------------------------------------------------------

export PATH="$HOME/.local/share/mise/shims:$HOME/.local/bin:$HOME/.atuin/bin:$PATH"

# retry <attempts> <cmd…> — re-run a flaky network step on failure with linear
# backoff. The release CDNs these installers hit (mise.run, setup.atuin.sh,
# GitHub releases, PyPI, …) intermittently throw transient TLS/handshake errors
# ("packet length too long", "received corrupt message", unauthenticated GitHub
# API rate-limit) that clear on a retry; without this a single blip aborts the
# whole bringup under `set -euo pipefail`. Returns the last failure's status if
# every attempt fails — so a genuinely-broken critical step still propagates.
retry() {
	local -r max="$1"; shift
	local n=1
	until "$@"; do
		local rc=$?
		if (( n >= max )); then
			echo "install-personal-tools: '$1' failed after $max attempts (rc=$rc)" >&2
			return "$rc"
		fi
		echo "install-personal-tools: '$1' attempt $n/$max failed (rc=$rc); retrying in $((n * 5))s…" >&2
		sleep "$((n * 5))"
		n=$((n + 1))
	done
}

# optional <cmd…> — retry, but on persistent failure warn and continue instead
# of aborting. For personal-preference tools (atuin, starship, claude, sd,
# xonsh) whose absence degrades comfort but does not break the container; mise
# and `mise install` stay fatal (the project toolchain depends on them).
optional() {
	retry 3 "$@" || echo "install-personal-tools: optional '$1' failed after retries; continuing without it" >&2
}

# Each network installer is a function so `retry`/`optional` can re-run the
# whole pipeline (curl | sh) as one unit — pipefail fails the pipe on a curl
# error, which retry then catches.
install_mise()     { curl -fsSL https://mise.run | sh; }
install_atuin()    { curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | sh; }
install_starship() { curl -sS https://starship.rs/install.sh | sh -s -- -y -b "$HOME/.local/bin"; }

# mise: upstream-recommended install (drops binary into ~/.local/bin). Critical
# — everything below resolves through mise — so a persistent failure aborts.
command -v mise >/dev/null || retry 3 install_mise

# atuin: upstream install script (drops binary into ~/.atuin/bin, not ~/.local/bin)
[[ -x "$HOME/.atuin/bin/atuin" ]] || optional install_atuin

# starship: upstream install script
command -v starship >/dev/null || optional install_starship

# claude: Anthropic-recommended install, pinned to $CLAUDE_VERSION. The guard is
# version-aware (not just `command -v`) so a stale install gets re-pinned — the
# installer's VERSION arg also downgrades. install.sh accepts [stable|latest|VERSION].
claude_have="$(command -v claude >/dev/null 2>&1 && claude --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)"
install_claude() { curl -fsSL https://claude.ai/install.sh | bash -s -- "$CLAUDE_VERSION"; }
[[ "$claude_have" == "$CLAUDE_VERSION" ]] || optional install_claude

# sd: GitHub release binary (chmln/sd is not packaged in Fedora).
if ! command -v sd >/dev/null; then
	case "$(uname -m)" in
		x86_64)  sd_target="x86_64-unknown-linux-musl" ;;
		aarch64) sd_target="aarch64-unknown-linux-musl" ;;
		*)       echo "install-personal-tools: no sd release for arch '$(uname -m)'" >&2; exit 1 ;;
	esac
	sd_tmp="$(mktemp -d)"
	install_sd() {
		curl -fsSL "https://github.com/chmln/sd/releases/download/v${SD_VERSION}/sd-v${SD_VERSION}-${sd_target}.tar.gz" \
			| tar -xz -C "$sd_tmp" --strip-components=1
	}
	if optional install_sd && [[ -f "$sd_tmp/sd" ]]; then
		install -Dm 0755 "$sd_tmp/sd" "$HOME/.local/bin/sd"
	fi
	rm -rf "$sd_tmp"
fi

# ---------------------------------------------------------------------------
# Shared: xonsh + xontribs into user site-packages
#
# pip-install pinned xonsh[ptk] (the [ptk] extra pulls prompt_toolkit, which
# xontrib-fzf-widgets imports at load time; plain `xonsh` install leaves it
# off and load fails with ModuleNotFoundError). xontribs come from the repo's
# xontrib-requirements.txt — bind-mounted in containers at /dotfiles-utils/,
# accessed via the script's own dir in toolbox.
# ---------------------------------------------------------------------------
# `toolbox enter` reads the host's $SHELL and uses it as the container's
# shell, ignoring the container's /etc/passwd (toolbox bug containers/
# toolbox#908). chsh inside the toolbox is therefore useless — the actual
# bash → xonsh hook lives in configs/shell-fedora/.bashrc, gated on the
# container marker. Hence: no chsh here. Just install xonsh + xontribs.
optional pip install --user "xonsh[ptk]==${XONSH_VERSION}"

script_dir="$(cd "$(dirname "$0")" && pwd)"
optional xonsh -c "xpip install --requirement '${script_dir}/xontrib-requirements.txt'"

# ---------------------------------------------------------------------------
# Toolbox-only: host terminfo mirror
#
# The host→toolbox and toolbox→host wrappers (toolbox-run, devpod, xdg-open,
# swaymsg) live as stowed files under configs/toolbox/.local/bin/. They land
# in $HOME via `make symlinks-fedora` — no install-time work needed here.
# ---------------------------------------------------------------------------
if [[ "$MODE" == "toolbox" ]]; then
	# Terminfo from host: kitty/ghostty ship terminfo with their host packages,
	# but the toolbox base ncurses doesn't carry xterm-kitty/xterm-ghostty, so
	# entering the toolbox from either terminal errors with "terminfo entry
	# not found". Copy via host root at /run/host into shared $HOME/.terminfo
	# (visible to host + every toolbox/devpod that shares $HOME).
	mkdir -p "$HOME/.terminfo/x"
	for term in xterm-kitty xterm-ghostty; do
		src="/run/host/usr/share/terminfo/x/$term"
		if [[ -f "$src" ]]; then
			install -m 0644 "$src" "$HOME/.terminfo/x/$term"
		fi
	done
fi

# ---------------------------------------------------------------------------
# devpod-only: realise project mise config inside the container
# ---------------------------------------------------------------------------
if [[ "$MODE" == "devpod" ]]; then
	# Critical: installs the project toolchain. Retry transient download/TLS
	# blips (mise has its own per-tool retry, but a hard CDN/SLSA-fetch error
	# still surfaces here); a persistent failure aborts the bringup.
	retry 3 mise install
fi
