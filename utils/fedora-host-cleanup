#!/usr/bin/env bash

set -euo pipefail

# Unlayer dev-tool packages from existing Fedora Atomic hosts to bring them in
# line with Pattern B (toolbox-as-outer). New machines coming through the USB
# bootstrap don't need this — `workstation-bootstrap/fedora-bootstrap.sh`
# already omits these packages from the rpm-ostree install list.
#
# After a successful run, reboot for the layer change to take effect, then
# `make fedora` to provision the toolbox with the same tools (and more) inside.

# git is deliberately NOT in this list: the host needs git for `git clone`
# during bootstrap and for `git pull` to refresh the dotfiles repo. xonsh,
# tmux, gcc are pure dev tools that moved to the toolbox under Pattern B.
to_unlayer=(xonsh tmux gcc)

echo "Unlayering dev tools from host (Pattern B): ${to_unlayer[*]}"

# Filter to packages that were `rpm-ostree install`-layered, NOT base-image
# packages (which can't be uninstalled, only overridden). `rpm -q` would match
# both and `rpm-ostree uninstall` on a base package fails under `set -e`. The
# `requested-packages` array in `rpm-ostree status --json` is the right list;
# parse it with python3 (always on Fedora Atomic, handles multi-line JSON
# correctly, no extra deps).
layered=$(rpm-ostree status --json | python3 -c '
import json, sys
data = json.load(sys.stdin)
for dep in data.get("deployments", []):
    if dep.get("booted"):
        for pkg in dep.get("requested-packages", []):
            print(pkg)
        break
')

needs_uninstall=()
for pkg in "${to_unlayer[@]}"; do
	if grep -qxF "$pkg" <<<"$layered"; then
		needs_uninstall+=("$pkg")
	fi
done

if [[ ${#needs_uninstall[@]} -eq 0 ]]; then
	echo "Nothing to unlayer — host is already minimal."
	exit 0
fi

echo "Found layered: ${needs_uninstall[*]}"
sudo rpm-ostree uninstall -y "${needs_uninstall[@]}"

cat <<'EOM'

=== Unlayer staged. ===

REBOOT now for the changes to take effect, then:

    cd ~/work/my/dotfiles
    make fedora            # provisions the `tools` toolbox with the dev stack

EOM
