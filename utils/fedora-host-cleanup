#!/usr/bin/env bash

set -euo pipefail

# Unlayer dev-tool packages from existing Fedora Atomic hosts to bring them in
# line with Pattern B (toolbox-as-outer). New machines coming through the USB
# bootstrap don't need this — `workstation-bootstrap/fedora-bootstrap.sh`
# already omits these packages from the rpm-ostree install list.
#
# After a successful run, reboot for the layer change to take effect, then
# `make fedora` to provision the toolbox with the same tools (and more) inside.

to_unlayer=(xonsh tmux git gcc)

echo "Unlayering dev tools from host (Pattern B): ${to_unlayer[*]}"

# `rpm -q` still works on rpm-ostree systems as a query of the running
# deployment, and is more robust than parsing `rpm-ostree status --json`
# (whose array spans multiple lines, defeating line-oriented grep).
needs_uninstall=()
for pkg in "${to_unlayer[@]}"; do
	if rpm -q "$pkg" >/dev/null 2>&1; then
		needs_uninstall+=("$pkg")
	fi
done

if [[ ${#needs_uninstall[@]} -eq 0 ]]; then
	echo "Nothing to unlayer — host is already minimal."
	exit 0
fi

echo "Found layered: ${needs_uninstall[*]}"
sudo rpm-ostree uninstall -y "${needs_uninstall[@]}"

cat <<'EOM'

=== Unlayer staged. ===

REBOOT now for the changes to take effect, then:

    cd ~/work/my/dotfiles
    make fedora            # provisions the `tools` toolbox with the dev stack

EOM
