#!/usr/bin/env bash
#
# Wrapper: allocate a per-project loopback IP, then exec `devpod up`.
#
# Project name = basename of $PWD. The allocator updates /etc/hosts on
# first invocation per project, then is a no-op. The chosen IP is exported
# as LOOPBACK_IP for .devcontainer.json's runArgs to consume via
# `${localEnv:LOOPBACK_IP}`.
#
# Usage:  cd <project-repo> && devpod-up [extra devpod up args...]
#         Or alias `dpup=devpod-up` in your shell rc.

set -euo pipefail

project=$(basename "$PWD")
script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

LOOPBACK_IP=$("$script_dir/devpod-allocate-loopback-ip" "$project")
export LOOPBACK_IP

echo "devpod-up: project=$project ip=$LOOPBACK_IP" >&2
exec devpod up "$@"
