#!/usr/bin/env bash

set -euo pipefail

AMNEZIA_VERSION="${AMNEZIA_VERSION:-4.8.15.4}"
INSTALL_DIR="${INSTALL_DIR:-${HOME}/.local/opt/amnezia}"

tarball="AmneziaVPN_${AMNEZIA_VERSION}_linux_x64.tar"
url="https://github.com/amnezia-vpn/amnezia-client/releases/download/${AMNEZIA_VERSION}/${tarball}"

workdir=$(mktemp -d)
trap 'rm -rf "$workdir"' EXIT

# No checksum verification: amnezia-vpn publishes no official hashes alongside
# releases, so HTTPS from GitHub releases is the available integrity guarantee.
curl -fsSL -o "$workdir/$tarball" "$url"

# The tarball ships a Qt installer-framework .bin (not a runnable launcher).
# Drop it in a stable location; the user runs the wizard once to complete the
# actual install, after which AmneziaVPN owns its own launcher + .desktop entry.
rm -rf "$INSTALL_DIR"
mkdir -p "$INSTALL_DIR"
tar -xf "$workdir/$tarball" -C "$INSTALL_DIR"

installer="$(find "$INSTALL_DIR" -maxdepth 2 -type f -name '*Installer*.bin' | head -n 1 || true)"
if [[ -z "$installer" ]]; then
	echo "install-amneziavpn: installer .bin not found under $INSTALL_DIR — tarball layout changed?" >&2
	exit 1
fi

chmod +x "$installer"

cat <<EOM

AmneziaVPN installer staged at:

    $installer

Run it once to complete installation (Qt wizard). The wizard creates
its own launcher binary and .desktop entry; this dotfiles script does
not need to be re-run unless AMNEZIA_VERSION bumps.

EOM
