#!/usr/bin/env bash

set -euo pipefail

# Host-only guard: this target manages host-side state (flatpak install,
# toolbox/devpod container creation, systemd services). Re-running it from
# inside the toolbox dies with "flatpak: command not found" deep in
# install-flatpaks; fail fast at the top instead.
if [[ -f /run/.toolboxenv ]]; then
	echo "fedora-after-install: must be run from the host shell, not inside a toolbox." >&2
	echo "  Exit the toolbox (Ctrl-D), then: cd ~/projects/my/dotfiles && make fedora" >&2
	exit 1
fi

# Run from repo root so bare util-script paths resolve regardless of caller CWD.
cd "$(dirname "$0")/.."

utils/install-flatpaks
utils/install-amneziavpn
utils/install-devpod

# Toolbox: full dev environment per Pattern B (toolbox-as-outer). The
# `install-personal-tools` script is the single source of truth for the
# personal CLI stack and is also used as the postCreateCommand inside every
# per-project DevPod container.
toolbox create -y tools || true
toolbox run -c tools bash "$(pwd)/utils/install-personal-tools" toolbox

# keyd: copy the user-managed config into /etc and (re)start the service.
# Requires the 'keyd' package from the USB Tier-1 rpm-ostree step.
sudo mkdir -p /etc/keyd
sudo install -m 0644 "$HOME/.local/share/keyd/default.conf" /etc/keyd/default.conf
sudo systemctl enable keyd
sudo systemctl restart keyd
