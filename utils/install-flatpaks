#!/usr/bin/env bash

set -euo pipefail

flatpak remote-add --if-not-exists --user flathub https://dl.flathub.org/repo/flathub.flatpakrepo

flatpak install -y --user flathub \
	app.zen_browser.zen \
	com.slack.Slack \
	org.telegram.desktop \
	us.zoom.Zoom \
	org.localsend.localsend_app \
	md.obsidian.Obsidian \
	com.transmissionbt.Transmission \
	com.calibre_ebook.calibre \
	io.mpv.Mpv

# Without this, xdg-open (host directly, or via the toolbox xdg-open wrapper)
# falls back to Firefox / the base-image default. The XDG_DATA_DIRS prepend
# makes xdg-settings resolve the user-flatpak-exported desktop file even when
# /etc/profile.d/flatpak.sh hasn't been sourced (non-login shells, fresh-boot
# TTY bootstrap). `env -u BROWSER` is required because xdg-settings refuses
# to mutate MIME defaults while $BROWSER overrides them — env.xsh sets
# $BROWSER=xdg-open, which inherits when `make fedora` runs from xonsh.
export XDG_DATA_DIRS="${HOME}/.local/share/flatpak/exports/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
env -u BROWSER xdg-settings set default-web-browser app.zen_browser.zen.desktop
