#!/usr/bin/env bash

set -euo pipefail

flatpak remote-add --if-not-exists --user flathub https://dl.flathub.org/repo/flathub.flatpakrepo

# Chromium is not a second daily browser: it backs the Yandex Music web-app
# (Hyper+m). Firefox-based Zen can't set a per-site app_id on Wayland, so a
# Chromium `--app` window is the only way to give the web-app its own
# workspace-bindable identity (see configs/sway/.config/sway/config.d/70-hyper-apps.conf).
# Geary + GNOME Calendar are the mail/calendar defaults; Evolution and
# Thunderbird are installed alongside for trialling MS-365 connectivity.
flatpak install -y --user flathub \
	app.zen_browser.zen \
	org.chromium.Chromium \
	com.slack.Slack \
	org.telegram.desktop \
	us.zoom.Zoom \
	org.localsend.localsend_app \
	org.gnome.Geary \
	org.gnome.Evolution \
	org.mozilla.Thunderbird \
	org.gnome.Calendar \
	md.obsidian.Obsidian \
	com.transmissionbt.Transmission \
	com.calibre_ebook.calibre \
	io.mpv.Mpv

# Without this, xdg-open (host directly, or via the toolbox xdg-open wrapper)
# falls back to Firefox / the base-image default. The XDG_DATA_DIRS prepend
# makes xdg-settings resolve the user-flatpak-exported desktop file even when
# /etc/profile.d/flatpak.sh hasn't been sourced (non-login shells, fresh-boot
# TTY bootstrap). `env -u BROWSER` is required because xdg-settings refuses
# to mutate MIME defaults while $BROWSER overrides them — env.xsh sets
# $BROWSER=xdg-open, which inherits when `make fedora` runs from xonsh.
export XDG_DATA_DIRS="${HOME}/.local/share/flatpak/exports/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
env -u BROWSER xdg-settings set default-web-browser app.zen_browser.zen.desktop

# LocalSend wants TCP 53317 (transfers) + UDP 53317 (mDNS discovery) reachable
# from LAN peers. Without these, Fedora can SEND to other devices but other
# devices can't SEND to Fedora (Mac→Fedora hits ConnectionRefused). Guarded on
# firewalld being active so this is a no-op on systems without it.
if systemctl is-active --quiet firewalld; then
	sudo firewall-cmd --add-port=53317/tcp --add-port=53317/udp --permanent
	sudo firewall-cmd --reload
fi
